# ============================================================
# EIA Multi-Agent System — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# --- Provider Selection -------------------------------------------
# LLM provider: openai | anthropic | gemini | ollama
LLM_PROVIDER=openai

# Embedding provider: openai | gemini | ollama (anthropic not supported)
EMBEDDING_PROVIDER=openai

# --- OpenAI (required if LLM_PROVIDER or EMBEDDING_PROVIDER = openai) ---
# Get your key: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Anthropic (required if LLM_PROVIDER = anthropic) ---
# Get your key: https://console.anthropic.com/settings/keys
# Note: Anthropic does NOT support embeddings — pair with openai/gemini/ollama for EMBEDDING_PROVIDER
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Google Gemini (required if LLM_PROVIDER or EMBEDDING_PROVIDER = gemini) ---
# Get your key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=models/text-embedding-004

# --- Ollama (local/offline — no API key needed) ---
# Install: https://ollama.com  then run: ollama pull llama3
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# --- Database (REQUIRED) ------------------------------------------
# PostgreSQL connection string with pgvector extension
# Format: postgresql://user:password@host:port/dbname
# After creating the DB, run: CREATE EXTENSION IF NOT EXISTS vector;
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/eia_db

# --- Deployment ---------------------------------------------------
RENDER_ENV=development
